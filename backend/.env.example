PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/ai-tools-directory

# JWT Secret - Generate a strong random secret for production (min 32 characters)
JWT_SECRET=your_jwt_secret_here

# CORS Configuration
# Development: Leave empty to allow all localhost origins (http://localhost:* and http://127.0.0.1:*)
# Production: Comma-separated list of allowed origins (REQUIRED)
# Examples:
#   Development: CORS_ORIGIN=
#   Production:  CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGIN=

# Frontend URL (for password reset and email verification emails)
FRONTEND_URL=http://localhost:5173

# Resend Email Service Configuration
RESEND_API_KEY=your_resend_api_key_here
SMTP_FROM="Your Name <your-email@example.com>"

# Admin Credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_secure_password_here

# Cloudinary Credentials
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
